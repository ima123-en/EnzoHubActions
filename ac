        Instance.new("UICorner", bg).CornerRadius = UDim.new(1, 0)

        dot = Instance.new("Frame", bg)
        dot.Size = UDim2.new(0, 16, 0, 16)
        dot.Position = UDim2.new(toggleState and 1 or 0, toggleState and -18 or 2, 0.5, -8)
        dot.BackgroundColor3 = toggleState and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(80, 80, 90)
        dot.BorderSizePixel = 0
        Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

        setStateVisual(toggleState)

        bg.MouseButton1Click:Connect(function()
            if momentary then
                setStateVisual(true)
                if onToggleClick then onToggleClick(true) end
                task.delay(0.05, function()
                    setStateVisual(false)
                    if onToggleClick then onToggleClick(false) end
                end)
            else
                toggleState = not toggleState
                setStateVisual(toggleState)
                if onToggleClick then onToggleClick(toggleState) end
                if not noSaveToggle then SaveSettings() end
            end
        end)

        ActionRows[name] = {
            SetState = function(v) setStateVisual(v) end,
            SetKeyText = function(t) kb.Text = t end,
            TriggerMomentary = function()
                if momentary then
                    setStateVisual(true)
                    if onToggleClick then onToggleClick(true) end
                    task.delay(0.05, function()
                        setStateVisual(false)
                        if onToggleClick then onToggleClick(false) end
                    end)
                end
            end
        }
    else
        ActionRows[name] = {
            SetKeyText = function(t) kb.Text = t end,
        }
    end
end

