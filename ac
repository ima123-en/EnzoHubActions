table.insert(US.Connections, UserInputService.InputBegan:Connect(function(i, gp)
    if gp then return end
    if i.UserInputType == Enum.UserInputType.Keyboard then
        local k = i.KeyCode.Name

        if k == US.RejoinKey then
            DoRejoin()
        elseif k == US.KickKey then
            DoKick()
        elseif k == US.ResetKey then
            DoReset()
            if ActionRows["Reset"] and ActionRows["Reset"].TriggerMomentary then ActionRows["Reset"].TriggerMomentary() end
        elseif k == US.InstantCloneKey then
            instantCloneUnified()
        elseif k == US.AutoBuyKey then
            US.AutoBuy = not US.AutoBuy
            if ActionRows["Auto Buy"] then ActionRows["Auto Buy"].SetState(US.AutoBuy) end
            SaveSettings()
        elseif k == US.AutoTurretKey then
            AutoTurretEnabled = not AutoTurretEnabled
            if ActionRows["Auto Turret"] then ActionRows["Auto Turret"].SetState(AutoTurretEnabled) end
        elseif k == US.DropBrainKey then
            runDropBrainrot()
            if ActionRows["Drop Brainrot"] and ActionRows["Drop Brainrot"].TriggerMomentary then ActionRows["Drop Brainrot"].TriggerMomentary() end
        end
    elseif i.UserInputType == Enum.UserInputType.MouseButton1 then
        if US.ClickToAP and hoverTarget then
            triggerOneCommand(hoverTarget)
        end
    end
end))

function US.Disable()
    US.Running = false
    for _, c in pairs(US.Connections) do pcall(function() c:Disconnect() end) end
    US.Connections = {}
    SaveSettings()
    if Gui then Gui:Destroy() end
    HL.Parent = nil
    if circle then circle:Destroy() end
end
