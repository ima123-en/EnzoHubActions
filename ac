local isRespawning_US = false

local function instantRespawn_US()
    if isRespawning_US then return end
    isRespawning_US = true
    US.IgnoreNextSteal = true
    local char = LocalPlayer.Character
    if not char then isRespawning_US = false US.IgnoreNextSteal = false return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildWhichIsA("Humanoid")
    if not hrp or not hum then isRespawning_US = false US.IgnoreNextSteal = false return end
    local savedCFrame = hrp.CFrame
    local savedCam = Workspace.CurrentCamera.CFrame
    local savedTool = nil
    for _, c in ipairs(char:GetChildren()) do
        if c:IsA("Tool") then savedTool = c.Name break end
    end
    hrp.CFrame = CFrame.new(9999999, 1000000000, -500000000)
    hrp.AssemblyLinearVelocity = Vector3.zero
    hum.Health = 0
    local startTime = tick()
    local newChar = nil
    while tick() - startTime < 3 do
        if LocalPlayer.Character and LocalPlayer.Character ~= char then
            newChar = LocalPlayer.Character
            break
        end
        task.wait(0.05)
    end
    if newChar then
        local newHRP = newChar:WaitForChild("HumanoidRootPart", 2)
        local newHum = newChar:WaitForChild("Humanoid", 2)
        if newHRP then
            task.wait(0.1)
            newHRP.CFrame = savedCFrame
            newHRP.AssemblyLinearVelocity = Vector3.zero
            newHRP.AssemblyAngularVelocity = Vector3.zero
            Workspace.CurrentCamera.CFrame = savedCam
        end
        if savedTool and newHum then
            task.spawn(function()
                task.wait(0.2)
                local bp = LocalPlayer:WaitForChild("Backpack", 2)
                if bp then
                    local tool = bp:FindFirstChild(savedTool) or newChar:FindFirstChild(savedTool)
                    if tool then
                        newHum:EquipTool(tool)
                    end
                end
            end)
        end
    end
    task.delay(3, function()
        US.IgnoreNextSteal = false
    end)
    isRespawning_US = false
end

local function DoReset()
    instantRespawn_US()
end

local function EquipTool(name)
    local char = LocalPlayer.Character
    if not char then return nil end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return nil end
    local bp = LocalPlayer:FindFirstChild("Backpack")
    local tool = char:FindFirstChild(name) or (bp and bp:FindFirstChild(name))
    if tool then
        hum:UnequipTools()
        task.wait()
        hum:EquipTool(tool)
    end
    return tool
end

local function instantCloneUnified()
    if _G._UnifiedIsCloning then return end
    _G._UnifiedIsCloning = true
    pcall(function()
        local char = LocalPlayer.Character
        if not char then return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hum or not hrp then return end
        local cloner = EquipTool("Quantum Cloner")
        if not cloner then return end
        task.wait(0.1)
        pcall(function() cloner:Activate() end)
        local cloneName = tostring(LocalPlayer.UserId) .. "_Clone"
        local clone
        local t0 = tick()
        while tick() - t0 < 5 do
            clone = Workspace:FindFirstChild(cloneName)
            if clone then break end
            task.wait(0.05)
        end
        if not clone then return end
        local tf = PlayerGui:FindFirstChild("ToolsFrames")
        local qcf = tf and tf:FindFirstChild("QuantumCloner")
        local btn = qcf and qcf:FindFirstChild("TeleportToClone")
        if not btn then return end
        btn.Visible = true
        if typeof(firesignal) == "function" then
            pcall(function()
                firesignal(btn.MouseButton1Click)
                firesignal(btn.MouseButton1Down)
                firesignal(btn.MouseButton1Up)
            end)
        else
            local inset = GuiService:GetGuiInset()
            local pos   = btn.AbsolutePosition + btn.AbsoluteSize * 0.5
            VirtualInputManager:SendMouseButtonEvent(pos.X+inset.X, pos.Y+inset.Y, 0, true,  game, 1)
            task.wait(0.05)
            VirtualInputManager:SendMouseButtonEvent(pos.X+inset.X, pos.Y+inset.Y, 0, false, game, 1)
        end
    end)
    _G._UnifiedIsCloning = false
end

local function extractItem(txt, pattern)
    local l = txt:lower()
    local idx = l:find(pattern)
    if idx then
        local raw = txt:sub(idx + #pattern)
        return raw:gsub(" from you.*", ""):gsub("[!%.]", "")
    end
    return nil
end

local function CheckText(txt)
    if type(txt) ~= "string" or txt == "" then return end
    local l = string.lower(txt)
    for _, word in ipairs(StealWords) do
        if l:find(word) then
            local item = extractItem(txt, "is stealing ") or extractItem(txt, "stole your ") or extractItem(txt, "stole ")
            if item then
                US.StealStatus[LocalPlayer.Name] = {expire = tick() + 5, item = item}
            end
            break
        end
    end
end

local function HookUI(obj)
    if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
        CheckText(obj.Text)
        table.insert(US.Connections, obj:GetPropertyChangedSignal("Text"):Connect(function() CheckText(obj.Text) end))
    end
end

for _, g in ipairs(PlayerGui:GetChildren()) do
    for _, d in ipairs(g:GetDescendants()) do HookUI(d) end
