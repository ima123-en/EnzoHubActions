    kb.MouseButton1Click:Connect(function()
        if waiting then return end
        waiting = true
        kb.Text = "..."
        local conn
        conn = UserInputService.InputBegan:Connect(function(i,gp)
            if gp then return end
            if i.UserInputType == Enum.UserInputType.Keyboard then
                local new = i.KeyCode.Name
                kb.Text = new
                waiting = false
                conn:Disconnect()
                if onKeyChange then onKeyChange(new) end
                SaveSettings()
            end
        end)
    end)

    local toggleState = initialState
    local bg, dot

    local function setStateVisual(on)
        if not hasToggle then return end
        toggleState = on
        TweenService:Create(dot, TweenInfo.new(0.18, Enum.EasingStyle.Back), {
            Position = UDim2.new(on and 1 or 0, on and -18 or 2, 0.5, -8),
            BackgroundColor3 = on and Color3.fromRGB(255,255,255) or Color3.fromRGB(80,80,90)
        }):Play()
        TweenService:Create(bg, TweenInfo.new(0.18), {
            BackgroundColor3 = on and Color3.fromRGB(255,255,255) or Color3.fromRGB(35,35,40)
        }):Play()
    end

    if hasToggle then
        bg = Instance.new("TextButton", h)
        bg.Size = UDim2.new(0, 40, 0, 20)
        bg.Position = UDim2.new(1, -55, 0.5, -10)
        bg.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
        bg.BorderSizePixel = 0
        bg.AutoButtonColor = false
