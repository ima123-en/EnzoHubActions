local function extractItem(txt, pattern)
    local l = txt:lower()
    local idx = l:find(pattern)
    if idx then
        local raw = txt:sub(idx + #pattern)
        return raw:gsub(" from you.*", ""):gsub("[!%.]", "")
    end
    return nil
end

local function CheckText(txt)
    if type(txt) ~= "string" or txt == "" then return end
    local l = string.lower(txt)
    for _, word in ipairs(StealWords) do
        if l:find(word) then
            local item = extractItem(txt, "is stealing ") or extractItem(txt, "stole your ") or extractItem(txt, "stole ")
            if item then
                US.StealStatus[LocalPlayer.Name] = {expire = tick() + 5, item = item}
            end
            break
        end
    end
end

