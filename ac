local MIN_GS, MAX_GS = 20, 100

local function setGuiScaleFromAlpha(a, instant)
    a = math.clamp(a, 0, 1)
    local value = math.floor(MIN_GS + (MAX_GS - MIN_GS) * a + 0.5)
    US.GuiScale = value
    if not GuiScaleInput:IsFocused() then
        GuiScaleInput.Text = tostring(value) .. "%"
    end
    local scale = 0.3 + (1.0 - 0.3) * ((value - MIN_GS) / (MAX_GS - MIN_GS))
    if instant then
        GlobalScale.Scale = scale
    else
        TweenService:Create(GlobalScale, TweenInfo.new(0.15), {Scale = scale}):Play()
    end
    GuiSliderFill.Size = UDim2.new(a, 0, 1, 0)
    GuiSliderKnob.Position = UDim2.new(a, -5, 0.5, -5)
    SaveSettings()
end

task.defer(function()
    local a = (US.GuiScale - MIN_GS) / (MAX_GS - MIN_GS)
    setGuiScaleFromAlpha(a, true)
end)

GuiSliderBg.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 then
        guiScaleDragging = true
        local rel = (i.Position.X - GuiSliderBg.AbsolutePosition.X) / GuiSliderBg.AbsoluteSize.X
        setGuiScaleFromAlpha(rel, false)
    end
end)
GuiSliderBg.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 then
        guiScaleDragging = false
    end
end)

UserInputService.InputChanged:Connect(function(i)
