local isRespawning_US = false

local function fastInstantRespawn_US()
    if isRespawning_US then return end
    isRespawning_US = true
    US.IgnoreNextSteal = true

    local Net = ReplicatedStorage:FindFirstChild("Packages", 2) and ReplicatedStorage.Packages:FindFirstChild("Net", 2)

    local remote
    if Net then
        local children = Net:GetChildren()
        for i = 1, #children - 1 do
            if children[i] and children[i+1] and string.find(children[i].Name, "Tools/Cooldown") then
                remote = children[i+1]
                break
            end
        end
    end

    local char = LocalPlayer.Character
    local savedCFrame, savedCam, savedToolName
    if char then
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChildWhichIsA("Humanoid")
        if hrp then savedCFrame = hrp.CFrame end
        if Workspace.CurrentCamera then savedCam = Workspace.CurrentCamera.CFrame end
        if hum then
            for _, c in ipairs(char:GetChildren()) do
                if c:IsA("Tool") then
                    savedToolName = c.Name
                    break
                end
            end
        end
    end

    local originalOrder = {}
    do
        local bp = LocalPlayer:FindFirstChild("Backpack")
        if bp then
            for _, t in ipairs(bp:GetChildren()) do
                if t:IsA("Tool") then
                    table.insert(originalOrder, t.Name)
                end
            end
        end
    end

    local savedTools = {}
    do
        local bp = LocalPlayer:FindFirstChild("Backpack")
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then pcall(function() hum:UnequipTools() end) end
            for _, t in ipairs(char:GetChildren()) do
                if t:IsA("Tool") then table.insert(savedTools, t); t.Parent = nil end
            end
        end
        if bp then
            for _, t in ipairs(bp:GetChildren()) do
                if t:IsA("Tool") then table.insert(savedTools, t); t.Parent = nil end
            end
        end
    end

    LocalPlayer.Character = nil
    local sending = true
    local loopConnection
    local _respawnThrottle = 0

    if remote then
        local fire = remote.FireServer
        loopConnection = RunService.Heartbeat:Connect(function(dt)
            if not sending then
                if loopConnection then loopConnection:Disconnect() loopConnection = nil end
                return
            end
            _respawnThrottle = _respawnThrottle + dt
            if _respawnThrottle >= 0.016 then
                _respawnThrottle = 0
                pcall(fire, remote, "f888ee6e-c86d-46e1-93d7-0639d6635d42", LocalPlayer, "balloon")
            end
            if sending and LocalPlayer.Character then
                LocalPlayer.Character = nil
            end
        end)
    else
        if char then
            local hum = char:FindFirstChildWhichIsA("Humanoid")
            if hum then hum.Health = 0 end
        end
    end

    local function restoreToolsWithOrder(newBp, newChar)
        if not newBp then return end

        local toolsByName = {}
        for _, t in ipairs(savedTools) do
            if t and t:IsA("Tool") then
                toolsByName[t.Name] = toolsByName[t.Name] or {}
                table.insert(toolsByName[t.Name], t)
            end
        end

        local finalList = {}

        for _, name in ipairs(originalOrder) do
            local list = toolsByName[name]
            if list and #list > 0 then
                local inst = table.remove(list, 1)
                table.insert(finalList, inst)
                if #list == 0 then
                    toolsByName[name] = nil
                end
            end
        end

        for _, list in pairs(toolsByName) do
            for _, inst in ipairs(list) do
                table.insert(finalList, inst)
            end
        end

        for _, t in ipairs(finalList) do
            if t and t.Parent ~= newBp then
                t.Parent = newBp
            end
        end

        savedTools = {}

        if savedToolName and newChar then
            local hum = newChar:FindFirstChildWhichIsA("Humanoid")
            if hum then
                task.delay(0.2, function()
                    local tool = newBp:FindFirstChild(savedToolName) or newChar:FindFirstChild(savedToolName)
                    if tool then hum:EquipTool(tool) end
                end)
            end
        end
    end

    local conn
    conn = LocalPlayer.CharacterAdded:Connect(function(newChar)
        sending = false
        if loopConnection then loopConnection:Disconnect() loopConnection = nil end
        if conn then conn:Disconnect() end
        task.spawn(function()
            local newBp = LocalPlayer:WaitForChild("Backpack", 3)
            if newBp then
                restoreToolsWithOrder(newBp, newChar)
            end
            if savedCFrame or savedCam then
                local hrp = newChar:WaitForChild("HumanoidRootPart",2)
                if hrp and savedCFrame then
                    hrp.CFrame = savedCFrame
                    hrp.AssemblyLinearVelocity = Vector3.zero
                    hrp.AssemblyAngularVelocity = Vector3.zero
                end
                if savedCam and Workspace.CurrentCamera then
                    Workspace.CurrentCamera.CFrame = savedCam
                end
            end
        end)
        task.delay(1, function()
            US.IgnoreNextSteal = false
            isRespawning_US = false
        end)
    end)

    task.delay(4, function()
        if isRespawning_US then
            sending = false
            if loopConnection then loopConnection:Disconnect() loopConnection = nil end
            local curBp = LocalPlayer:FindFirstChild("Backpack")
            if curBp then
                for _, t in ipairs(savedTools) do
                    if t then t.Parent = curBp end
                end
            end
            savedTools = {}
            US.IgnoreNextSteal = false
            isRespawning_US = false
        end
    end)
end

